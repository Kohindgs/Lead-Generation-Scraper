# ─────────────────────────────────────────────────────────────
#  DGENIUS SOLUTIONS – Lead Generation Scraper
#  Copy this file to .env and fill in your credentials
# ─────────────────────────────────────────────────────────────

# ── AGENCY INFO ──────────────────────────────────────────────
AGENCY_NAME="DGenius Solutions"
AGENCY_WEBSITE="https://www.dgeniussolutions.com"
AGENCY_EMAIL="hello@dgeniussolutions.com"
AGENCY_PHONE="+1-XXX-XXX-XXXX"
SENDER_NAME="Your Name"
SENDER_TITLE="Business Development Head"

# ── LINKEDIN CREDENTIALS ──────────────────────────────────────
LINKEDIN_EMAIL="your_linkedin_email@example.com"
LINKEDIN_PASSWORD="your_linkedin_password"
LINKEDIN_SESSION_COOKIE=""       # optional: li_at cookie for faster auth

# ── GOOGLE / SERPAPI ─────────────────────────────────────────
SERPAPI_KEY="your_serpapi_key"           # https://serpapi.com
GOOGLE_MAPS_API_KEY="your_gmaps_api_key"
GOOGLE_CSE_ID="your_custom_search_engine_id"
GOOGLE_API_KEY="your_google_api_key"

# ── AI MODELS ────────────────────────────────────────────────
ANTHROPIC_API_KEY="your_anthropic_api_key"
OPENAI_API_KEY="your_openai_api_key"

# ── EMAIL FINDER ─────────────────────────────────────────────
HUNTER_API_KEY="your_hunter_io_api_key"   # https://hunter.io
APOLLO_API_KEY="your_apollo_io_api_key"   # https://apollo.io

# ── PROXY (optional but recommended to avoid bans) ────────────
USE_PROXY=false
PROXY_HOST="proxy.example.com"
PROXY_PORT="8080"
PROXY_USER="proxy_user"
PROXY_PASS="proxy_password"
PROXY_ROTATION_URL=""    # URL returning a fresh proxy each call

# ── DATABASE ─────────────────────────────────────────────────
DB_PATH="data/leads.db"

# ── SCRAPING BEHAVIOUR ────────────────────────────────────────
REQUEST_DELAY_MIN=2          # seconds – minimum delay between requests
REQUEST_DELAY_MAX=6          # seconds – maximum delay between requests
MAX_LEADS_PER_RUN=200        # safety cap
HEADLESS_BROWSER=true        # set false for debugging

# ── NOTIFICATIONS ────────────────────────────────────────────
SLACK_WEBHOOK_URL=""         # optional Slack alerts
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"     # Gmail: use App Password (not your main password)

# ── EMAIL SENDING LIMITS (prevents spam flags) ───────────────────────────────
MAX_EMAILS_PER_DAY=80             # max emails to send per day
EMAIL_DELAY_MIN=45                # seconds between emails (min)
EMAIL_DELAY_MAX=120               # seconds between emails (max)

# ── LINKEDIN POST SCRAPER & SCHEDULER ─────────────────────────────────────────
POST_SCRAPE_INTERVAL_HOURS=4     # how often to run the post scraper
MAX_POSTS_PER_RUN=60             # max posts to collect per scheduled run
MIN_SCORE_TO_DM=55               # minimum opportunity score (0-100) to auto-DM
AUTO_SEND_DMS=false              # set true to auto-send DMs (use with caution)
MAX_POST_AGE_HOURS=48            # ignore posts older than this
DAILY_EXPORT_HOUR=8              # UTC hour for daily Excel export (0-23)

# ── META AI CONTENT REPLY SYSTEM ──────────────────────────────────────────────
# Step-by-step setup: see docs/META_SETUP.md

# Meta Graph API (get from developers.facebook.com)
META_PAGE_ACCESS_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxxxxx"   # Long-lived Page token
META_PAGE_ID="123456789012345"                           # Your Facebook Page ID
META_IG_ACCOUNT_ID="17841400000000000"                  # Instagram Business Account ID

# Webhook server (receives Google Form submissions)
META_WEBHOOK_SECRET="choose-a-strong-random-secret-here"
META_WEBHOOK_VERIFY_TOKEN="choose-another-random-token"

# Google Form URL — append PSID_PLACEHOLDER for per-user pre-filled links
# See docs/GOOGLE_FORM_SETUP.md for how to generate this URL
META_GOOGLE_FORM_URL="https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform?usp=pp_url&entry.XXXXXXX=PSID_PLACEHOLDER"

# Gmail / Google Workspace SMTP for sending approved brand reports
META_SMTP_HOST="smtp.gmail.com"
META_SMTP_PORT=587
META_SMTP_USER="your@dgeniussolutions.com"          # Your Google Business email
META_SMTP_PASS="xxxx xxxx xxxx xxxx"               # Google App Password (16 chars)

# Google Sheets lead tracker
GOOGLE_SHEET_ID="1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms"   # from Sheet URL
GOOGLE_SERVICE_ACCOUNT_JSON="config/google-service-account.json"   # path to key file

# Polling behaviour
META_SCAN_INTERVAL_MINUTES=15     # how often to poll Meta for new comments
META_MAX_POSTS_PER_SCAN=25        # max posts to check per scan
